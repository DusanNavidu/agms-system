            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Greenhouse B\",\n    \"description\": \"Seedling Area\",\n    \"area\": \"600sqm\",\n    \"minTemp\": 22.0,\n    \"maxTemp\": 28.0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/zones", "host": ["localhost"], "port": "8080", "path": ["api", "zones"] }
          }
        },
        {
          "name": "Get Zone By ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "test-jwt-token", "type": "string" }] },
            "method": "GET",
            "url": { "raw": "http://localhost:8080/api/zones/1", "host": ["localhost"], "port": "8080", "path": ["api", "zones", "1"] }
